# ============================================
# CallVault Environment Variables
# ============================================
#
# Copy this file to .env and fill in the values.
# Lines marked [required] are needed for basic functionality.
# Lines marked [optional] enable specific features.
#
# NEVER commit your .env file — it contains secrets.


# ============================================
# SUPABASE — Core Infrastructure
# ============================================

# [required] Supabase project URL and keys
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# [required] Frontend-accessible (VITE_ prefix = visible in browser, these are public)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-public-anon-key

# [optional] Direct database connection strings (for scripts/migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres
SESSION_POOLER_URL=postgresql://postgres:password@your-project-id.pooler.supabase.com:5432/postgres
DEDICATED_POOLER_URL=postgresql://postgres:password@your-project-id.pooler.supabase.com:5432/postgres
SUPABASE_DB_PASSWORD=your-db-password


# ============================================
# CORS — Allowed Origins
# ============================================

# [optional] Comma-separated list of allowed origins for CORS.
# Defaults to production domains + localhost if not set.
ALLOWED_ORIGINS=https://callvault.vercel.app,https://app.callvaultai.com,http://localhost:8080,http://localhost:5173


# ============================================
# APP URLs
# ============================================

# [optional] Used for redirects and email links
APP_URL=https://callvault.vercel.app
SITE_URL=https://callvault.vercel.app
PUBLIC_SITE_URL=https://callvault.vercel.app


# ============================================
# FATHOM — Meeting Sync (OAuth)
# ============================================

# [required for Fathom integration] OAuth credentials per environment
FATHOM_OAUTH_CLIENT_ID_DEV=your-dev-client-id
FATHOM_OAUTH_CLIENT_SECRET_DEV=your-dev-client-secret
FATHOM_OAUTH_CLIENT_ID_PRODUCTION=your-prod-client-id
FATHOM_OAUTH_CLIENT_SECRET_PRODUCTION=your-prod-client-secret

# [optional] Webhook verification for Fathom push events
FATHOM_OAUTH_WEBHOOK_SECRET=your-fathom-webhook-secret


# ============================================
# ZOOM — Meeting Sync (OAuth)
# ============================================

# [required for Zoom integration] Get from https://marketplace.zoom.us/develop/create
ZOOM_OAUTH_CLIENT_ID=your-zoom-client-id
ZOOM_OAUTH_CLIENT_SECRET=your-zoom-client-secret
ZOOM_APP_CLIENT_ID=your-zoom-app-client-id
ZOOM_APP_CLIENT_SECRET=your-zoom-app-client-secret

# [required for Zoom webhooks] From Zoom Marketplace > Feature > Event Subscriptions
ZOOM_WEBHOOK_SECRET_TOKEN=your-zoom-webhook-secret-token


# ============================================
# GOOGLE — OAuth & YouTube
# ============================================

# [optional] Google OAuth for Google Meet integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# [optional] YouTube Data API for video imports
YOUTUBE_DATA_API_KEY=your-youtube-data-api-key


# ============================================
# AI / LLM APIs
# ============================================

# [required] Primary AI provider
OPENAI_API_KEY=sk-...

# [required] Multi-model routing via OpenRouter
OPENROUTER_API_KEY=sk-or-...

# [optional] Additional AI providers
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSy...
HUGGINGFACE_API_KEY=hf_...


# ============================================
# PAYMENTS — Polar
# ============================================

# [optional] Polar.sh for subscriptions and checkout
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_ORGANIZATION_ID=your-polar-org-id
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret


# ============================================
# PAYMENTS — Stripe (Legacy / Migration)
# ============================================

# [optional] Stripe keys if migrating from Stripe
STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ============================================
# EMAIL — Resend
# ============================================

# [optional] Transactional email via Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_...
RESEND_DOMAIN_VERIFIED=false


# ============================================
# OBSERVABILITY — Sentry
# ============================================

# [optional] Frontend error tracking (public DSN, safe for browser)
VITE_SENTRY_DSN=https://xxxx@xxx.ingest.sentry.io/xxx

# [optional] Build-time only (for source map uploads, keep private)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=sntrys_...


# ============================================
# OBSERVABILITY — Langfuse
# ============================================

# [optional] LLM observability and tracing
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_URL=https://cloud.langfuse.com


# ============================================
# EXTERNAL SERVICES
# ============================================

# [optional] Transcript API for meeting transcript extraction
TRANSCRIPT_API_KEY=your-transcript-api-key

# [optional] Firecrawl for web scraping
FIRECRAWL_API_KEY=your-firecrawl-api-key

# [optional] WebCrawler API
WEBCRAWLERAPI_KEY=your-webcrawler-api-key

# [optional] Cloudflare for DNS/domain management
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_BASE_DOMAIN=your-base-domain.com

# [optional] Dynadot domain registrar API
DYNADOT_API_KEY=your-dynadot-api-key
DYNADOT_SECRET_KEY=your-dynadot-secret-key


# ============================================
# TESTING & DEVELOPMENT
# ============================================

# [optional] Test user credentials for e2e tests and dev-browser
CALLVAULTAI_LOGIN=test@example.com
CALLVAULTAI_LOGIN_PASSWORD=your-test-password

# [optional] Vercel-specific (set automatically in Vercel deployments)
SB_PUBLISHABLE_KEY=sb_publishable_...
SB_SECRET=sb_secret_...
